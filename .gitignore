# .NET build output
bin/
obj/
*.user
*.suo
.vs/
*.nupkg

# Node / npm
node_modules/
dist/
.vite/
*.tsbuildinfo

# Native builds (CMake intermediate output only)
native/*/build/

# Ignore stray native libs in build output, but KEEP the committed runtime
# binaries under any */runtimes/**/native/ folder. The leading **/ matters:
# the real path is src/Zeus.Dsp/runtimes/... so a bare 'Zeus.Dsp/...' negation
# never matches and the WDSP/miniaudio DLLs get stripped from the repo —
# every fresh clone then fails with DllNotFoundException('wdsp').
*.so
*.dylib
*.dll
!**/runtimes/**

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.swp
*.swo
.vscode/settings.json

# Runtime
*.log
logs/
*.db
*.db-journal

# Secrets / certs
*.pem
*.crt
*.key
!*.sample

# NovaSdr specific
wdsp-wisdom/
~/.novasdr/
